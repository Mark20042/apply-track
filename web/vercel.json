{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://apply-track-jkb9.onrender.com/api/$1"
        }
    ],
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}